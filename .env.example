# ── Core ──
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── API Auth (required for all POST endpoints) ──
API_SECRET=your-secret-key-here

# ── Slack (Stage 3+) ──
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXXXXX/BXXXXXX/XXXXXXXXXXXXXXXX

# ── Email Sending (Stage 4: Follow-Up) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=outreach@yourcompany.com
SMTP_PASS=...
SENDER_NAME=GrowthClaw
PHYSICAL_ADDRESS=Austin, TX

# ── Email Monitoring (Stage 4: Reply Detection) ──
IMAP_HOST=imap.gmail.com
IMAP_USER=outreach@yourcompany.com
IMAP_PASS=...

# ── Meeting Booking (Stage 4) ──
CALENDLY_LINK=https://calendly.com/yourcompany/demo

# ── Product Integration (Stage 5: Convert & Close) ──
# Pluggable — point to any SaaS product's API
PRODUCT_API_URL=https://api.yourproduct.com
PRODUCT_API_KEY=...
PRODUCT_SIGNUP_URL=https://yourproduct.com/signup

# ── Stripe (Stage 5: Payment Tracking) ──
STRIPE_API_KEY=sk_...
